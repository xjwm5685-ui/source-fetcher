# Auto detect text files and perform LF normalization
* text=auto

# Go source files
*.go text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# PowerShell scripts
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Documentation
*.md text
*.txt text
LICENSE text
AUTHORS text
CHANGELOG text

# YAML files
*.yml text
*.yaml text

# JSON files
*.json text

# Go module files
go.mod text
go.sum text

# Git files
.gitignore text
.gitattributes text

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.o binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.tgz binary
*.7z binary
*.rar binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Export ignore
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
