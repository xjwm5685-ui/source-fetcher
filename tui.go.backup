	tuiPageQueue
	tuiPageMirrors
	tuiPageBatch
)

const (
	tuiSearchFocusSource = iota
	tuiSearchFocusQuery
	tuiSearchFocusOutput
	tuiSearchFocusMirror
	tuiSearchFocusLimit
	tuiSearchFocusAuth
	tuiSearchFocusArch
	tuiSearchFocusInstaller
	tuiSearchFocusResume
	tuiSearchFocusChunks
	tuiSearchFocusResults
	tuiSearchFocusCount
)

const (
	tuiBatchFocusConfig = iota
	tuiBatchFocusTasks
	tuiBatchFocusCount
)

const tuiRefreshInterval = 200 * time.Millisecond

